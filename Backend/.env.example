# 이 파일을 복사하여 .env 로 이름 변경 후 실제 값을 입력하세요
# cp .env.example .env

# PostgreSQL 연결 정보
DB_HOST=localhost
DB_PORT=5432
DB_NAME=keti_dashboard
DB_USER=postgres
DB_PASSWORD=여기에_비밀번호_입력

# 서버 포트
PORT=3000

# 이미지 저장 루트 경로
IMAGE_ROOT=../Image

# Cloudinary 설정 (https://cloudinary.com 무료 가입 후 발급)
CLOUDINARY_CLOUD_NAME=여기에_cloud_name_입력
CLOUDINARY_API_KEY=여기에_api_key_입력
CLOUDINARY_API_SECRET=여기에_api_secret_입력
